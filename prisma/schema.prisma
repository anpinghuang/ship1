// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  tier          Tier      @default(FREE)
  projects      Project[]
  rules         Rule[]
  posts         Post[]
  connections   ProviderConnection[]
}

// App Specific Tables
enum Tier {
  FREE
  PRO
}

model Project {
  id             String          @id @default(cuid())
  userId         String
  githubRepoId   String?
  githubRepoName String?
  tracking       Boolean         @default(true)
  cadence        String          @default("per_commit") // "per_commit" | "daily"
  autoDrafts     Boolean         @default(false)
  autoApprove    Boolean         @default(false)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  rules          Rule[]
  events         ActivityEvent[]
  posts          Post[]
  commits        Commit[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Commit {
  sha         String   @id
  projectId   String
  message     String   @db.Text
  author      String?
  url         String   // GitHub commit URL
  committedAt DateTime
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  posts       Post[]
  createdAt   DateTime @default(now())
}

model Rule {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  name      String
  type      RuleType
  config    Json     // e.g. { "keywords": ["WIP", "test"], "branch": "main" }
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum RuleType {
  IGNORE_BRANCH
  IGNORE_MESSAGE
  FORMATTING
}

model ActivityEvent {
  id        String   @id @default(cuid())
  projectId String
  eventType String   // 'push', 'pull_request', etc.
  payload   Json     // raw webhook payload
  processed Boolean  @default(false)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Post {
  id            String     @id @default(cuid())
  userId        String
  projectId     String?
  commitSha     String?
  content       String     @db.Text
  variants      Json?      // alternative generations
  status        PostStatus @default(DRAFT)
  platformIds   Json?      // e.g. { "x": "123456789", "x_url": "..." }
  impressions   Int        @default(0)
  replies       Int        @default(0)
  publishedAt   DateTime?
  lastFetchedAt DateTime?
  nextFetchAt   DateTime?
  fetchCount    Int        @default(0)
  fetchLocked   Boolean    @default(false)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  project       Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  commit        Commit?    @relation(fields: [commitSha], references: [sha], onDelete: SetNull)
  scheduledFor  DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([nextFetchAt])
  @@index([userId, status])
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

model ProviderConnection {
  id                String    @id @default(cuid())
  userId            String
  provider          String    // "github" | "x"
  providerAccountId String    // GitHub user ID or X user ID
  username          String?   // @handle for display
  scope             String?   // granted OAuth scopes
  accessTokenEnc    String?   @db.Text  // AES-256-GCM encrypted
  refreshTokenEnc   String?   @db.Text  // AES-256-GCM encrypted (X refresh token)
  expiresAt         DateTime?
  connectedAt       DateTime  @default(now())
  lastValidatedAt   DateTime  @default(now())
  revokedAt         DateTime? // null = active, set = disconnected
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}
